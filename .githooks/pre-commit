#!/usr/bin/env bash
# Pre-commit hook: detect secrets before they get committed
set -euo pipefail

RED='\033[0;31m'
NC='\033[0m'

PATTERNS=(
    'AKIA[0-9A-Z]{16}'                    # AWS Access Key
    'aws_secret_access_key\s*='           # AWS Secret Key assignment
    'github_pat_[a-zA-Z0-9_]{22,}'        # GitHub PAT (fine-grained)
    'ghp_[a-zA-Z0-9]{36}'                 # GitHub PAT (classic)
    'gho_[a-zA-Z0-9]{36}'                 # GitHub OAuth
    'sk-[a-zA-Z0-9]{20,}'                 # OpenAI/Anthropic API Key
    'xox[bpors]-[a-zA-Z0-9-]+'            # Slack Token
    'AIza[0-9A-Za-z_-]{35}'               # Google API Key
    'PRIVATE KEY-----'                     # Private Key
    'password\s*=\s*["\x27][^"\x27]+'     # Hardcoded password
    'api[_-]?key\s*=\s*["\x27][^"\x27]+'  # API key assignment
    'secret\s*=\s*["\x27][^"\x27]+'       # Secret assignment
)

FOUND=0
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

[ -z "$STAGED_FILES" ] && exit 0

for file in $STAGED_FILES; do
    # Skip files that contain pattern definitions (not actual secrets)
    [[ "$file" == .githooks/* ]] && continue
    [[ "$file" == scripts/check-secrets.sh ]] && continue
    # Skip binary files and example files
    [[ "$file" == *.example ]] && continue
    [[ "$file" == *.md ]] && continue
    file -b --mime "$file" 2>/dev/null | grep -q "binary" && continue

    for pattern in "${PATTERNS[@]}"; do
        if grep -PnH "$pattern" "$file" 2>/dev/null; then
            echo -e "${RED}[SECRET DETECTED]${NC} in $file (pattern: $pattern)"
            FOUND=1
        fi
    done
done

if [ "$FOUND" -eq 1 ]; then
    echo ""
    echo -e "${RED}=== COMMIT BLOCKED ===${NC}"
    echo "Potential secrets detected in staged files."
    echo "Move secrets to ~/.bashrc.local or env/.env (gitignored)."
    echo ""
    echo "To bypass (DANGEROUS): git commit --no-verify"
    exit 1
fi

exit 0
